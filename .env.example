# Copy this file to .env and fill in your credentials
# Never commit .env to version control

# CoinEx API credentials (from https://www.coinex.com/en/apikey)
COINEX_ACCESS_ID=
COINEX_SECRET_KEY=

# Telegram alerts (optional - get token from @BotFather)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Grafana admin password (if using monitoring profile)
GRAFANA_PASSWORD=changeme
